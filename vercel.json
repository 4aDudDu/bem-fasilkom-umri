        { "src": "/(img|images|uploads|css|js|favicon.ico|robots.txt)/(.*)", "dest": "/$1/$2" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "public": true,
    "buildCommand": "vite build",
    "outputDirectory": "public",
    "env": {
